<%- include("./partials/header") %>

<div class="min-h-screen flex items-center justify-center bg-[#0b1120] text-white relative overflow-hidden">

  <div class="absolute w-[400px] h-[400px] bg-blue-500/20 rounded-full blur-3xl top-[-100px] left-[-100px]"></div>
  <div class="absolute w-[300px] h-[300px] bg-cyan-400/20 rounded-full blur-3xl bottom-[-100px] right-[-100px]"></div>

  <div class="relative z-10 w-full max-w-lg p-6">

    <div class="bg-white/5 backdrop-blur-lg border border-white/10 rounded-2xl shadow-2xl p-8">

      <h2 class="text-2xl font-semibold mb-6 text-center">Upload File</h2>

      <form action="/upload" method="POST" enctype="multipart/form-data" class="space-y-6">

        <div>
          <label class="block mb-2 text-sm text-gray-400">Choose File</label>

          <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-blue-500/30 rounded-xl cursor-pointer hover:bg-blue-500/10 transition">
            
            <span class="text-3xl mb-2 text-blue-400">+</span>
            <span class="text-sm text-gray-400">Click to select file</span>

            <input type="file" name="file" class="hidden" required>
          </label>
        </div>

        <div>
          <label class="block mb-2 text-sm text-gray-400">Rename File (optional)</label>
          <input 
            type="text" 
            name="customName"
            placeholder="Enter new file name..."
            class="w-full px-4 py-2 rounded-md bg-[#020617] border border-blue-500/20 focus:ring-2 focus:ring-blue-400 outline-none placeholder-gray-500"
          />
        </div>

        
        <div class="flex justify-between items-center">

          <a href="/" class="text-sm text-gray-400 hover:text-blue-400">
            ← Back to Home
          </a>

          <button 
            type="submit"
            class="px-6 py-2 rounded-md bg-blue-500 hover:bg-blue-600 transition"
          >
            Upload
          </button>

        </div>

      </form>

    </div>

  </div>

</div>

<%- include("./partials/footer") %>